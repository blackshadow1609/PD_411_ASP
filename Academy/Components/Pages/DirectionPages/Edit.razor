@page "/directions/edit"
@rendermode InteractiveServer
@using Microsoft.EntityFrameworkCore
@using Academy.Models
@inject IDbContextFactory<Academy.Data.AcademyContext> DbFactory
@inject NavigationManager NavigationManager

<PageTitle>Edit Direction</PageTitle>

<h1>Edit Direction</h1>

<hr />
@if (direction is null)
{
    <p><em>Loading...</em></p>
}
else
{
    <div class="row">
        <div class="col-md-4">
            <EditForm Model="direction" OnValidSubmit="UpdateDirection" FormName="edit">
                <DataAnnotationsValidator />
                <ValidationSummary class="text-danger" />
                
                <div class="mb-3">
                    <label class="form-label">ID:</label>
                    <input type="number" class="form-control" value="@direction.direction_id" disabled />
                </div>
                
                <div class="mb-3">
                    <label class="form-label">Direction Name:</label>
                    <InputText @bind-Value="direction.direction_name" class="form-control" />
                    <ValidationMessage For="() => direction.direction_name" class="text-danger" />
                    @if (!string.IsNullOrEmpty(errorMessage))
                    {
                        <div class="text-danger mt-1">@errorMessage</div>
                    }
                </div>
                <button type="submit" class="btn btn-primary" disabled="@isSubmitting">
                    @if (isSubmitting)
                    {
                        <span>Saving...</span>
                    }
                    else
                    {
                        <span>Save</span>
                    }
                </button>
            </EditForm>
        </div>
    </div>
}

<div>
    <a href="/directions">Back to List</a>
</div>

@code {
    [SupplyParameterFromQuery]
    private int direction_id { get; set; }

    private Direction? direction;
    private string errorMessage = "";
    private bool isSubmitting = false;

    protected override async Task OnInitializedAsync()
    {
        using var context = DbFactory.CreateDbContext();
        direction = await context.Directions.FirstOrDefaultAsync(m => m.direction_id == direction_id);
        
        if (direction is null)
        {
            NavigationManager.NavigateTo("/directions");
        }
    }

    private async Task UpdateDirection()
    {
        errorMessage = "";
        isSubmitting = true;
        StateHasChanged();
        
        try
        {
            using var context = DbFactory.CreateDbContext();
            
            var existingDirection = await context.Directions
                .FirstOrDefaultAsync(d => d.direction_id != direction!.direction_id &&
                    d.direction_name != null &&
                    d.direction_name.ToLower() == direction.direction_name.ToLower());
            
            if (existingDirection != null)
            {
                errorMessage = $"Direction '{direction!.direction_name}' already exists!";
                isSubmitting = false;
                StateHasChanged();
                return;
            }
            
            context.Entry(direction!).State = EntityState.Modified;
            await context.SaveChangesAsync();
            NavigationManager.NavigateTo("/directions");
        }
        catch (Exception ex)
        {
            errorMessage = $"Error: {ex.Message}";
            isSubmitting = false;
            StateHasChanged();
        }
    }
}