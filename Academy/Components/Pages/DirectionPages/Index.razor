@page "/directions"
@rendermode InteractiveServer
@using Microsoft.EntityFrameworkCore
@using Academy.Models
@using Academy.Data
@implements IAsyncDisposable
@inject IDbContextFactory<Academy.Data.AcademyContext> DbFactory

<PageTitle>Directions</PageTitle>

<h1>Directions</h1>

<p>
    <a href="directions/create">Create New</a>
</p>

<table class="table table-striped">
    <thead>
        <tr>
            <th>ID</th>
            <th>Name</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var direction in directions)
        {
            <tr>
                <td>@direction.direction_id</td>
                <td>@direction.direction_name</td>
                <td>
                    <a href="directions/edit?direction_id=@direction.direction_id">Edit</a> |
                    <a href="directions/details?direction_id=@direction.direction_id">Details</a> |
                    <a href="directions/delete?direction_id=@direction.direction_id">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>

@code {
    private List<Direction> directions = new();
    private AcademyContext context = default!;

    protected override async Task OnInitializedAsync()
    {
        context = DbFactory.CreateDbContext();
        await LoadDirections();
    }

    private async Task LoadDirections()
    {
        directions = await context.Directions
            .OrderBy(d => d.direction_id)
            .ToListAsync();
        StateHasChanged();
    }

    public async ValueTask DisposeAsync()
    {
        if (context != null)
            await context.DisposeAsync();
    }
}