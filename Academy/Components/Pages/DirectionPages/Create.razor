@page "/directions/create"
@rendermode InteractiveServer
@using Microsoft.EntityFrameworkCore
@using Academy.Models
@inject IDbContextFactory<Academy.Data.AcademyContext> DbFactory
@inject NavigationManager NavigationManager

<PageTitle>Create Direction</PageTitle>

<h1>Create Direction</h1>

<hr />
<div class="row">
    <div class="col-md-4">
        <EditForm Model="direction" OnValidSubmit="AddDirection" FormName="create">
            <DataAnnotationsValidator />
            <ValidationSummary class="text-danger" />
            
            <div class="mb-3">
                <label class="form-label">ID:</label>
                <input type="number" class="form-control" value="@direction.direction_id" disabled />
            </div>
            
            <div class="mb-3">
                <label class="form-label">Direction Name:</label>
                <InputText @bind-Value="direction.direction_name" class="form-control" />
                <ValidationMessage For="() => direction.direction_name" class="text-danger" />
                @if (!string.IsNullOrEmpty(errorMessage))
                {
                    <div class="text-danger mt-1">@errorMessage</div>
                }
            </div>
            
            <button type="submit" class="btn btn-primary" disabled="@isSubmitting">
                @if (isSubmitting)
                {
                    <span>Checking...</span>
                }
                else
                {
                    <span>Create</span>
                }
            </button>
        </EditForm>
    </div>
</div>

<div>
    <a href="/directions">Back to List</a>
</div>

@code {
    private Direction direction = new();
    private string errorMessage = "";
    private bool isSubmitting = false;

    protected override async Task OnInitializedAsync()
    {
        await GetNextAvailableId();
    }

    private async Task GetNextAvailableId()
    {
        using var context = DbFactory.CreateDbContext();
        
        var existingIds = await context.Directions
            .Select(d => d.direction_id)
            .OrderBy(id => id)
            .ToListAsync();
        
        byte nextId = 0;
        foreach (var id in existingIds)
        {
            if (id == nextId)
            {
                nextId++;
            }
            else
            {
                break;
            }
        }
        
        direction.direction_id = nextId;
    }

    private async Task AddDirection()
    {
        errorMessage = "";
        isSubmitting = true;
        StateHasChanged();
        
        try
        {
            using var context = DbFactory.CreateDbContext();
            
            var existingDirection = await context.Directions
                .FirstOrDefaultAsync(d => d.direction_name != null &&
                    d.direction_name.ToLower() == direction.direction_name.ToLower());
            
            if (existingDirection != null)
            {
                errorMessage = $"Direction '{direction.direction_name}' already exists!";
                isSubmitting = false;
                StateHasChanged();
                return;
            }
            
            context.Directions.Add(direction);
            await context.SaveChangesAsync();
            NavigationManager.NavigateTo("/directions");
        }
        catch (Exception ex)
        {
            errorMessage = $"Error: {ex.Message}";
            isSubmitting = false;
            StateHasChanged();
        }
    }
}