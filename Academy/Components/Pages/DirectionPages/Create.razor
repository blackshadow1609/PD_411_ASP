@page "/directions/create"
@rendermode InteractiveServer
@using Microsoft.EntityFrameworkCore
@using Academy.Models
@inject IDbContextFactory<Academy.Data.AcademyContext> DbFactory
@inject NavigationManager NavigationManager

<PageTitle>Create Direction</PageTitle>

<h1>Create Direction</h1>

<hr />
<div class="row">
    <div class="col-md-4">
        <EditForm Model="direction" OnValidSubmit="AddDirection" FormName="create">
            <DataAnnotationsValidator />
            <ValidationSummary class="text-danger" />
            
            <div class="mb-3">
                <label class="form-label">ID:</label>
                <InputNumber @bind-Value="idValue" class="form-control" min="0" max="255" />
                <ValidationMessage For="() => idValue" class="text-danger" />
            </div>
            
            <div class="mb-3">
                <label class="form-label">Direction Name:</label>
                <InputText @bind-Value="direction.direction_name" class="form-control" />
                <ValidationMessage For="() => direction.direction_name" class="text-danger" />
            </div>
            
            <button type="submit" class="btn btn-primary">Create</button>
        </EditForm>
    </div>
</div>

<div>
    <a href="/directions">Back to List</a>
</div>

@code {
    private Direction direction = new();
    private int idValue;

    private async Task AddDirection()
    {
        if (idValue < 0 || idValue > 255)
        {
            return;
        }
        
        direction.direction_id = (byte)idValue;
        
        using var context = DbFactory.CreateDbContext();
        context.Directions.Add(direction);
        await context.SaveChangesAsync();
        NavigationManager.NavigateTo("/directions");
    }
}