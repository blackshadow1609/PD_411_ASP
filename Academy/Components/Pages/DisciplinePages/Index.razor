@page "/disciplines"
@rendermode InteractiveServer
@using Microsoft.EntityFrameworkCore
@using Academy.Models
@using Academy.Data
@implements IAsyncDisposable
@inject IDbContextFactory<Academy.Data.AcademyContext> DbFactory

<PageTitle>Disciplines</PageTitle>

<h1>Disciplines</h1>

<p>
    <a href="/disciplines/create">Create New</a>
</p>

<table class="table table-striped">
    <thead>
        <tr>
            <th>ID</th>
            <th>Name</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var discipline in disciplines)
        {
            <tr>
                <td>@discipline.discipline_id</td>
                <td>@discipline.discipline_name</td>
                <td>
                    <a href="/disciplines/edit?discipline_id=@discipline.discipline_id">Edit</a> |
                    <a href="/disciplines/details?discipline_id=@discipline.discipline_id">Details</a> |
                    <a href="/disciplines/delete?discipline_id=@discipline.discipline_id">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>

@code {
    private List<Discipline> disciplines = new();
    private AcademyContext? context;

    protected override async Task OnInitializedAsync()
    {
        context = DbFactory.CreateDbContext();
        await LoadDisciplines();
    }

    private async Task LoadDisciplines()
    {
        if (context != null)
        {
            disciplines = await context.Disciplines.OrderBy(d => d.discipline_id).ToListAsync();
            StateHasChanged();
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (context != null)
            await context.DisposeAsync();
    }
}