@page "/disciplines/create"
@rendermode InteractiveServer
@using Microsoft.EntityFrameworkCore
@using Academy.Models
@inject IDbContextFactory<Academy.Data.AcademyContext> DbFactory
@inject NavigationManager NavigationManager

<PageTitle>Create Discipline</PageTitle>

<h1>Create Discipline</h1>

<hr />
<div class="row">
    <div class="col-md-4">
        <EditForm Model="discipline" OnValidSubmit="AddDiscipline" FormName="create">
            <DataAnnotationsValidator />
            <ValidationSummary class="text-danger" />
            
            <div class="mb-3">
                <label class="form-label">ID:</label>
                <input type="number" class="form-control" value="@discipline.discipline_id" disabled />
            </div>
            
            <div class="mb-3">
                <label class="form-label">Discipline Name:</label>
                <InputText @bind-Value="discipline.discipline_name" class="form-control" />
                <ValidationMessage For="() => discipline.discipline_name" class="text-danger" />
                @if (!string.IsNullOrEmpty(errorMessage))
                {
                    <div class="text-danger mt-1">@errorMessage</div>
                }
            </div>
            
            <button type="submit" class="btn btn-primary" disabled="@isSubmitting">
                @if (isSubmitting)
                {
                    <span>Saving...</span>
                }
                else
                {
                    <span>Create</span>
                }
            </button>
        </EditForm>
    </div>
</div>

<div>
    <a href="/disciplines">Back to List</a>
</div>

@code {
    private Discipline discipline = new();
    private string errorMessage = "";
    private bool isSubmitting = false;

    protected override async Task OnInitializedAsync()
    {
        await GetNextAvailableId();
    }

    private async Task GetNextAvailableId()
    {
        using var context = DbFactory.CreateDbContext();
        
        if (await context.Disciplines.AnyAsync())
        {
            var maxId = await context.Disciplines.MaxAsync(d => d.discipline_id);
            discipline.discipline_id = (short)(maxId + 1);
        }
        else
        {
            discipline.discipline_id = 0;
        }
    }

    private async Task AddDiscipline()
    {
        errorMessage = "";
        isSubmitting = true;
        StateHasChanged();

        try
        {
            using var context = DbFactory.CreateDbContext();
            
            // Check for duplicate name
            var existing = await context.Disciplines
                .FirstOrDefaultAsync(d => d.discipline_name != null &&
                    d.discipline_name.ToLower() == discipline.discipline_name.ToLower());
            
            if (existing != null)
            {
                errorMessage = $"Discipline '{discipline.discipline_name}' already exists!";
                isSubmitting = false;
                StateHasChanged();
                return;
            }
            
            context.Disciplines.Add(discipline);
            await context.SaveChangesAsync();
            NavigationManager.NavigateTo("/disciplines");
        }
        catch (Exception ex)
        {
            errorMessage = $"Error: {ex.Message}";
            isSubmitting = false;
            StateHasChanged();
        }
    }
}