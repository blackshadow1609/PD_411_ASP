@page "/disciplines/edit"
@rendermode InteractiveServer
@using Microsoft.EntityFrameworkCore
@using Academy.Models
@inject IDbContextFactory<Academy.Data.AcademyContext> DbFactory
@inject NavigationManager NavigationManager

<PageTitle>Edit Discipline</PageTitle>

<h1>Edit Discipline</h1>

<hr />
@if (discipline is null)
{
    <p><em>Loading...</em></p>
}
else
{
    <div class="row">
        <div class="col-md-4">
            <EditForm Model="discipline" OnValidSubmit="UpdateDiscipline" FormName="edit">
                <DataAnnotationsValidator />
                <ValidationSummary class="text-danger" />
                
                <div class="mb-3">
                    <label class="form-label">ID:</label>
                    <input type="number" class="form-control" value="@discipline.discipline_id" disabled />
                </div>
                
                <div class="mb-3">
                    <label class="form-label">Discipline Name:</label>
                    <InputText @bind-Value="discipline.discipline_name" class="form-control" />
                    <ValidationMessage For="() => discipline.discipline_name" class="text-danger" />
                    @if (!string.IsNullOrEmpty(errorMessage))
                    {
                        <div class="text-danger mt-1">@errorMessage</div>
                    }
                </div>
                
                <button type="submit" class="btn btn-primary" disabled="@isSubmitting">
                    @if (isSubmitting)
                    {
                        <span>Saving...</span>
                    }
                    else
                    {
                        <span>Save</span>
                    }
                </button>
            </EditForm>
        </div>
    </div>
}

<div>
    <a href="/disciplines">Back to List</a>
</div>

@code {
    [SupplyParameterFromQuery]
    private int discipline_id { get; set; }

    private Discipline? discipline;
    private string errorMessage = "";
    private bool isSubmitting = false;

    protected override async Task OnInitializedAsync()
    {
        using var context = DbFactory.CreateDbContext();
        discipline = await context.Disciplines.FirstOrDefaultAsync(m => m.discipline_id == discipline_id);
        
        if (discipline is null)
        {
            NavigationManager.NavigateTo("/disciplines");
        }
    }

    private async Task UpdateDiscipline()
    {
        if (discipline == null) return;
        
        errorMessage = "";
        isSubmitting = true;
        StateHasChanged();

        try
        {
            using var context = DbFactory.CreateDbContext();
            
            // Check for duplicate name (excluding current)
            var existing = await context.Disciplines
                .FirstOrDefaultAsync(d => d.discipline_id != discipline.discipline_id &&
                    d.discipline_name != null &&
                    d.discipline_name.ToLower() == discipline.discipline_name.ToLower());
            
            if (existing != null)
            {
                errorMessage = $"Discipline '{discipline.discipline_name}' already exists!";
                isSubmitting = false;
                StateHasChanged();
                return;
            }
            
            context.Entry(discipline).State = EntityState.Modified;
            await context.SaveChangesAsync();
            NavigationManager.NavigateTo("/disciplines");
        }
        catch (Exception ex)
        {
            errorMessage = $"Error: {ex.Message}";
            isSubmitting = false;
            StateHasChanged();
        }
    }
}