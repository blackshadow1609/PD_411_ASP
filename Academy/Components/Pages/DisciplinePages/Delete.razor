@page "/disciplines/delete"
@rendermode InteractiveServer
@using Microsoft.EntityFrameworkCore
@using Academy.Models
@inject IDbContextFactory<Academy.Data.AcademyContext> DbFactory
@inject NavigationManager NavigationManager

<PageTitle>Delete Discipline</PageTitle>

<h1>Delete Discipline</h1>

<h3>Are you sure you want to delete this?</h3>
<div>
    <hr />
    @if (discipline is null)
    {
        <p><em>Loading...</em></p>
    }
    else
    {
        <dl class="row">
            <dt class="col-sm-2">ID</dt>
            <dd class="col-sm-10">@discipline.discipline_id</dd>
        </dl>
        <dl class="row">
            <dt class="col-sm-2">Name</dt>
            <dd class="col-sm-10">@discipline.discipline_name</dd>
        </dl>
        
        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="alert alert-danger">@errorMessage</div>
        }
        
        <button class="btn btn-danger" @onclick="DeleteDiscipline">Delete</button>
        <a href="/disciplines" class="btn btn-secondary">Back to List</a>
    }
</div>

@code {
    [SupplyParameterFromQuery]
    private int discipline_id { get; set; }

    private Discipline? discipline;
    private string errorMessage = "";

    protected override async Task OnInitializedAsync()
    {
        using var context = DbFactory.CreateDbContext();
        discipline = await context.Disciplines.FirstOrDefaultAsync(m => m.discipline_id == discipline_id);
        
        if (discipline is null)
        {
            NavigationManager.NavigateTo("/disciplines");
        }
    }

    private async Task DeleteDiscipline()
    {
        if (discipline == null) return;
        
        try
        {
            using var context = DbFactory.CreateDbContext();
            
            // Проверяем, существует ли запись
            var toDelete = await context.Disciplines.FirstOrDefaultAsync(m => m.discipline_id == discipline.discipline_id);
            
            if (toDelete == null)
            {
                errorMessage = "Record not found!";
                StateHasChanged();
                return;
            }
            
            context.Disciplines.Remove(toDelete);
            int result = await context.SaveChangesAsync();
            
            if (result > 0)
            {
                NavigationManager.NavigateTo("/disciplines", true); // force reload
            }
            else
            {
                errorMessage = "Failed to delete the record.";
                StateHasChanged();
            }
        }
        catch (DbUpdateException ex)
        {
            errorMessage = "Cannot delete because this discipline is referenced by other records.";
            Console.WriteLine($"Delete error: {ex.Message}");
            StateHasChanged();
        }
        catch (Exception ex)
        {
            errorMessage = $"Error: {ex.Message}";
            Console.WriteLine($"Delete error: {ex.Message}");
            StateHasChanged();
        }
    }
}