@page "/groups/edit"
@rendermode InteractiveServer
@using Microsoft.EntityFrameworkCore
@using Academy.Models
@inject IDbContextFactory<Academy.Data.AcademyContext> DbFactory
@inject NavigationManager NavigationManager

<PageTitle>Edit Group</PageTitle>

<h1>Edit Group</h1>

<hr />
@if (group is null)
{
    <p><em>Loading...</em></p>
}
else
{
    <div class="row">
        <div class="col-md-4">
            <form @onsubmit="UpdateGroup">
                <div class="mb-3">
                    <label class="form-label">ID:</label>
                    <input type="number" class="form-control" value="@group.group_id" disabled />
                </div>
                
                <div class="mb-3">
                    <label class="form-label">Group Name:</label>
                    <input type="text" @bind="groupName" class="form-control" />
                </div>
                
                <div class="mb-3">
                    <label class="form-label">Direction ID:</label>
                    <input type="number" @bind="directionIdValue" class="form-control" />
                    <small class="text-muted">Enter Direction ID (0-255)</small>
                </div>
                
                <div class="mb-3">
                    <label class="form-label">Year:</label>
                    <input type="number" @bind="yearValue" class="form-control" />
                </div>
                
                <button type="submit" class="btn btn-primary">Save</button>
            </form>
        </div>
    </div>
}

<div>
    <a href="/groups">Back to List</a>
</div>

@code {
    [SupplyParameterFromQuery]
    private int group_id { get; set; }

    private Group? group;
    private string groupName = "";
    private int? directionIdValue;
    private int? yearValue;

    protected override async Task OnInitializedAsync()
    {
        using var context = DbFactory.CreateDbContext();
        group = await context.Groups.FirstOrDefaultAsync(m => m.group_id == group_id);
        
        if (group != null)
        {
            groupName = group.group_name ?? "";
            yearValue = group.year;
            directionIdValue = group.direction_id;
        }
        
        if (group is null)
        {
            NavigationManager.NavigateTo("/groups");
        }
    }

    private async Task UpdateGroup()
    {
        if (group == null) return;
        
        group.group_name = groupName;
        group.year = yearValue;
        group.direction_id = directionIdValue.HasValue ? (byte)directionIdValue.Value : (byte?)null;
        
        using var context = DbFactory.CreateDbContext();
        context.Entry(group).State = EntityState.Modified;
        await context.SaveChangesAsync();
        NavigationManager.NavigateTo("/groups");
    }
}