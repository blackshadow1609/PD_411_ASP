@page "/groups/delete"
@rendermode InteractiveServer
@using Microsoft.EntityFrameworkCore
@using Academy.Models
@inject IDbContextFactory<Academy.Data.AcademyContext> DbFactory
@inject NavigationManager NavigationManager

<PageTitle>Delete Group</PageTitle>

<h1>Delete Group</h1>

<h3>Are you sure you want to delete this?</h3>
<div>
    <hr />
    @if (group is null)
    {
        <p><em>Loading...</em></p>
    }
    else
    {
        <dl class="row">
            <dt class="col-sm-2">ID</dt>
            <dd class="col-sm-10">@group.group_id</dd>
        </dl>
        <dl class="row">
            <dt class="col-sm-2">Group Name</dt>
            <dd class="col-sm-10">@group.group_name</dd>
        </dl>
        <dl class="row">
            <dt class="col-sm-2">Direction ID</dt>
            <dd class="col-sm-10">@group.direction_id</dd>
        </dl>
        <dl class="row">
            <dt class="col-sm-2">Year</dt>
            <dd class="col-sm-10">@group.year</dd>
        </dl>
        
        <button class="btn btn-danger" @onclick="DeleteGroup">Delete</button>
        <a href="/groups" class="btn btn-secondary">Back to List</a>
    }
</div>

@code {
    [SupplyParameterFromQuery]
    private int group_id { get; set; }

    private Group? group;

    protected override async Task OnInitializedAsync()
    {
        using var context = DbFactory.CreateDbContext();
        group = await context.Groups.FirstOrDefaultAsync(m => m.group_id == group_id);
        
        if (group is null)
        {
            NavigationManager.NavigateTo("/groups");
        }
    }

    private async Task DeleteGroup()
    {
        using var context = DbFactory.CreateDbContext();
        context.Groups.Remove(group!);
        await context.SaveChangesAsync();
        NavigationManager.NavigateTo("/groups");
    }
}